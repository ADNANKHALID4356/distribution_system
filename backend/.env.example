# ========================================
# DISTRIBUTION SYSTEM - BACKEND CONFIGURATION
# Development/Local Environment Template
# ========================================
# INSTRUCTIONS:
# 1. Copy this file to .env
# 2. Update values with your actual configuration
# 3. NEVER commit the actual .env file to version control
# ========================================

# ==========================================
# SERVER CONFIGURATION
# ==========================================
PORT=5000
NODE_ENV=development

# ==========================================
# DATABASE CONFIGURATION (MySQL)
# ==========================================
# For local development
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=your_mysql_password_here
DB_NAME=distribution_system_db
DB_PORT=3306

# For remote/production database
# DB_HOST=your_remote_host.com
# DB_USER=your_database_user
# DB_PASSWORD=your_secure_password
# DB_NAME=distribution_system_db
# DB_PORT=3306

# ==========================================
# SQLite CONFIGURATION (Development Only)
# ==========================================
# Set to 'true' to use SQLite instead of MySQL for local development
# WARNING: SQLite is for development only, not for production
USE_SQLITE=false

# ==========================================
# JWT AUTHENTICATION
# ==========================================
# Generate a strong secret key for JWT tokens
# You can use: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_jwt_secret_key_here_change_this_to_random_string
JWT_EXPIRE=7d

# ==========================================
# COMPANY INFORMATION
# ==========================================
COMPANY_NAME=Your Company Name
COMPANY_WEBSITE=ummahtechinnovations.com

# ==========================================
# CURRENCY CONFIGURATION
# ==========================================
DEFAULT_CURRENCY=PKR
USD_TO_PKR_RATE=280

# ==========================================
# SECURITY NOTES
# ==========================================
# - Keep this file secure and never commit actual credentials
# - Use strong, unique passwords
# - Change default values before production deployment
# - Use environment-specific configurations
# - Consider using a secrets management service for production
