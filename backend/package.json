{
  "name": "distribution-system-backend",
  "version": "1.0.0",
  "description": "Backend API server for Distribution Management System - Enterprise-grade REST API with MySQL/SQLite support",
  "author": "Ummahtechinnovations",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "setup-db": "node setup-db.js",
    "build-standalone": "pkg standalone.js --targets node18-win-x64 --output ../desktop/backend-standalone/backend.exe",
    "test": "jest --forceExit --detectOpenHandles --testTimeout=30000",
    "test:verbose": "jest --verbose --forceExit --detectOpenHandles --testTimeout=30000"
  },
  "pkg": {
    "assets": [
      "src/**/*",
      ".env.production",
      ".env",
      "node_modules/better-sqlite3/**/*"
    ],
    "outputPath": "../desktop/backend-standalone"
  },
  "keywords": [
    "distribution",
    "management",
    "api",
    "mysql",
    "express",
    "nodejs"
  ],
  "license": "MIT",
  "dependencies": {
    "axios": "^1.13.2",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.5.0",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^5.1.0",
    "express-rate-limit": "^8.2.1",
    "jsonwebtoken": "^9.0.2",
    "mysql2": "^3.15.3"
  },
  "devDependencies": {
    "jest": "^30.2.0",
    "nodemon": "^3.1.11",
    "pkg": "^5.8.1",
    "supertest": "^7.2.2"
  }
}
