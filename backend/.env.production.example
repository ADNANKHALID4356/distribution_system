# ========================================
# DISTRIBUTION SYSTEM - BACKEND CONFIGURATION
# Production/Standalone Environment Template
# ========================================
# INSTRUCTIONS:
# 1. Copy this file to .env.production
# 2. Update ALL values with your production configuration
# 3. NEVER commit the actual .env.production file to version control
# 4. Rebuild backend after updating: npm run build-standalone
# ========================================

# ==========================================
# PRODUCTION SERVER CONFIGURATION
# ==========================================
PORT=5000
NODE_ENV=production

# ==========================================
# PRODUCTION DATABASE CONFIGURATION
# ==========================================
# IMPORTANT: Configure your remote MySQL server details here
# This server should be accessible from all client devices

# Remote MySQL Server
DB_HOST=your_production_database_host.com
DB_USER=your_production_db_user
DB_PASSWORD=your_secure_production_password
DB_NAME=distribution_system_db
DB_PORT=3306

# Examples:
# DB_HOST=192.168.1.100          # Local network server
# DB_HOST=mydb.example.com       # Domain name
# DB_HOST=aws-rds-endpoint.com   # Cloud hosted database

# ==========================================
# JWT AUTHENTICATION (PRODUCTION)
# ==========================================
# CRITICAL: Use a strong, unique secret for production
# Generate using: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CHANGE_THIS_TO_SECURE_RANDOM_SECRET_FOR_PRODUCTION
JWT_EXPIRE=7d

# ==========================================
# COMPANY INFORMATION
# ==========================================
COMPANY_NAME=Your Company Name
COMPANY_WEBSITE=ummahtechinnovations.com

# ==========================================
# CURRENCY CONFIGURATION
# ==========================================
DEFAULT_CURRENCY=PKR
USD_TO_PKR_RATE=280

# ==========================================
# DEPLOYMENT CHECKLIST
# ==========================================
# Before deploying to production, ensure:
# 
# ✓ Database server is accessible from client networks
# ✓ MySQL user has proper remote access permissions
# ✓ Firewall allows connections on port 3306
# ✓ JWT_SECRET is changed to a strong random value
# ✓ DB_PASSWORD is strong and secure
# ✓ All credentials are kept confidential
# ✓ Database backup strategy is in place
# ✓ SSL/TLS enabled for production database connections (recommended)
#
# After updating this file:
# 1. Ensure .env.production is in .gitignore
# 2. Rebuild backend: npm run build-standalone
# 3. Test connection before full deployment
