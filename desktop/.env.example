# ========================================
# DISTRIBUTION SYSTEM - FRONTEND CONFIGURATION
# Production Environment Example
# ========================================
# Copy this file to .env and update with your server URL

# ==========================================
# API SERVER URL
# ==========================================
# Point this to your production server
# Example: https://api.yourdomain.com/apic
# Or: http://your-server-ip:5000/api
REACT_APP_API_URL=http://localhost:5000/api

# ==========================================
# APPLICATION SETTINGS
# ==========================================
REACT_APP_NAME=Distribution Management System
REACT_APP_VERSION=1.0.0

# ==========================================
# COMPANY INFORMATION
# ==========================================
REACT_APP_COMPANY_NAME=Ummahtechinnovations
REACT_APP_COMPANY_WEBSITE=ummahtechinnovations.com

# ==========================================
# ENVIRONMENT
# ==========================================
NODE_ENV=production
GENERATE_SOURCEMAP=false
